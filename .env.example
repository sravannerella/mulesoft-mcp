# ──────────────────────────────────────────────
# Option 1: Username / Password auth
# ──────────────────────────────────────────────
ANYPOINT_USERNAME=your_username
ANYPOINT_PASSWORD=your_password

# ──────────────────────────────────────────────
# Option 2: Connected App auth (preferred for CI/CD)
# ──────────────────────────────────────────────
ANYPOINT_CLIENT_ID=your_client_id
ANYPOINT_CLIENT_SECRET=your_client_secret

# ──────────────────────────────────────────────
# Organisation & Environment (required)
# ──────────────────────────────────────────────
ANYPOINT_ORG_ID=your_org_id
# Leave blank to operate across all environments
ANYPOINT_ENV_ID=your_env_id

# ──────────────────────────────────────────────
# Optional tuning
# ──────────────────────────────────────────────
ANYPOINT_HOST=anypoint.mulesoft.com
CLI_TIMEOUT_MS=60000
CLI_MAX_RETRIES=3
RATE_LIMIT_RPS=10
LOG_LEVEL=info
CACHE_TTL_SECONDS=300
